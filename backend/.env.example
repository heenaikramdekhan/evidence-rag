# ==========================================================================
# Evidence-RAG configuration. Copy to `.env` and fill in.
# Everything here has a working default EXCEPT the LLM key.
# ==========================================================================

# --- LLM provider: "groq" (cloud free-tier) | "ollama" (fully local) ---
LLM_PROVIDER=groq

# --- Groq (https://console.groq.com — free, no credit card) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Ollama (fully offline fallback; run `ollama serve`) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# --- Embeddings (runs locally on CPU) ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- Storage ---
CHROMA_DIR=./data/chroma
COLLECTION_NAME=evidence

# --- Chunking ---
CHUNK_SIZE=700
CHUNK_OVERLAP=100

# --- Retrieval ---
TOP_K_VECTOR=10
TOP_K_BM25=10
TOP_K_RERANK=5
USE_RERANKER=true
